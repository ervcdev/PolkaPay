# Westend Asset Hub Network Configuration
WESTEND_ASSET_HUB_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io

# Wallet Configuration (Choose ONE method)
# METHOD 1: Mnemonic (Recommended for Talisman users)
MNEMONIC=your twelve word seed phrase here from talisman wallet

# METHOD 2: Private Key (Fallback method)
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Local Development
LOCAL_RPC_URL=http://localhost:8545

# Contract Addresses (populated after deployment)
