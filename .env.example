MOCK_USDT_CONTRACT_ADDRESS=

# Optional: Gas reporting and verification
REPORT_GAS=true
ETHERSCAN_API_KEY=your_api_key_here

# Frontend Configuration
NEXT_PUBLIC_KODAPAY_ADDRESS=
NEXT_PUBLIC_USDT_ADDRESS=
